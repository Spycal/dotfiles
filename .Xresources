! ~/.Xresources

!:================================:!
!:         COLOR SCHEMES          :!
!:================================:!

! special
*.background: #343D46
*.foreground: #D5DEE9
*.cursorColor: #D5DEE9

! normal 
*.color0: #21262C
*.color1: #EA4850
*.color2: #80B979
*.color3: #f9AE58
*.color4: #538CC6
*.color5: #B87AB8
*.color6: #52ADAD
*.color7: #B8BCC7

! bright
*.color8: #2B333B
*.color9: #EC5F67
*.color10: #99C794
*.color11: #F9B578
*.color12: #6699CC
*.color13: #C594C5
*.color14: #5FB3B3
*.color15: #A7ADBA

!:================================:!
!:      URXVT CONFIGURATION       :!
!:================================:!

URxvt.font: xft:Hack:style=Regular:pixelsize=14
URxvt.boldFont: xft:Hack:style=Bold:pixelsize=14
URxvt.italicFont: xft:Hack:style=Italic:pixelsize=14

URxvt.saveLines: 2048
URxvt.urgentOnBell: true
URxvt.scrollBar: false
URxvt.internalBorder: 24
URxvt.cursorBlink: true
URxvt.iso14755: false
URxvt.iso14755_52: false 
URxvt.depth: 32
!URxvt.transparency: false
!URxvt.shading: false

URxvt.perl-lib: ~/.urxvt/ext
URxvt.perl-ext-common: default,clipboard,url-select,keyboard-select,resize-font

!:================================:!
!:        URXVT KEYBINDS          :!
!:================================:!

!: copy and paste :!
URxvt.copyCommand: xclip -i selection clipboard
URxvt.pasteCommand: xclip -o selectio2n clipboard
URxvt.keysym.C-S-0x43: perl:clipboard:copy
URxvt.keysym.C-S-0x56: perl:clipboard:paste

!: resize font :!
URxvt.keysym.C-minus: resize-font:smaller
URxvt.keysym.C-plus: resize-font:bigger
URxvt.keysym.C-equal: resize-font:reset
URxvt.resize-font.step: 2



